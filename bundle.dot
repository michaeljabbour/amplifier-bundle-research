// amplifier-bundle-research — architecture
// A research-rigor toolkit: sharpen a question, lock the method, run it,
// critique it honestly, draft it, and format it for the venue — backed by
// specialist agents, always-on discipline, experiment-integrity tools, and
// figure/LaTeX/venue knowledge.
digraph research {
  rankdir=TB;
  bgcolor="white";
  fontname="Helvetica"; fontsize=18;
  labelloc=t; labeljust=c;
  label="amplifier-bundle-research\nSuperpowers for scientific rigor — from a sharpened question to a venue-ready artifact";

  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=0];
  edge [fontname="Helvetica", fontsize=9, color="#666666"];
  nodesep=0.35; ranksep=0.75;

  // ---- Entry points ----
  entry  [label="amplifier bundle add --app …research\n(full pipeline)", shape=note, fillcolor="#b3e0d8"];
  paper  [label="bundles/paper-only.md\n(lean “just write a paper” variant)", shape=note, fillcolor="#d8efe9"];

  // ---- The pipeline spine ----
  subgraph cluster_pipeline {
    label="Workflow  ·  six slash-command stages"; fontsize=13; color="#4C72B0"; style="rounded"; penwidth=1.5;
    node [fillcolor="#dce6f5"];
    q   [label="/question\nsharpen the claim"];
    sp  [label="/study-plan\nlock method · pre-register"];
    ex  [label="/execute\nrun · gather · pull evidence"];
    cr  [label="/critique\nhonest peer review"];
    dr  [label="/draft\nbuild the artifact"];
    pub [label="/publish\nformat for venue (gated)"];
    q -> sp -> ex -> cr -> dr -> pub [color="#4C72B0", penwidth=1.5];
  }

  // ---- Specialist agents (14), grouped by the stage they serve ----
  subgraph cluster_agents {
    label="Specialist agents (14)"; fontsize=13; color="#55A868"; style="rounded"; penwidth=1.5;
    node [fillcolor="#e2f0e6"];
    a_q   [label="Question & method\nhypothesis-designer · methodologist\npreregistration-reviewer"];
    a_ev  [label="Evidence & ideas\nstatistician · literature-scout\nidea-generator"];
    a_rev [label="Review\nhonest-critic · ml-paper-reviewer"];
    a_au  [label="Authoring\nresearch-paper-architect · research-technical-writer\nresearch-citation-manager · venue-formatter · figure-designer"];
    a_orch[label="Orchestration\nresearch-coordinator", fillcolor="#cfe6d6"];
  }

  // ---- Always-on discipline (behaviors) ----
  subgraph cluster_behaviors {
    label="Always-on discipline (behaviors)"; fontsize=13; color="#C44E52"; style="rounded"; penwidth=1.5;
    node [fillcolor="#f6e0e1"];
    b1 [label="honest-pivot · exploratory-labeling\nseparate confirmatory from exploratory"];
    b2 [label="stop-slop · cross-vendor-judge\ncache-only-verification\nprose quality · bias-resistant review"];
  }

  // ---- Tools & knowledge ----
  subgraph cluster_tools {
    label="Tools & knowledge"; fontsize=13; color="#8172B3"; style="rounded"; penwidth=1.5;
    node [fillcolor="#ece8f3"];
    t_exp [label="Experiment-integrity tools (6)\naudit · power · provenance\nresume · stage-analysis · hypothesis-block"];
    t_fig [label="PaperBanana figure tool\nmulti-agent · 8 quality vetoes"];
    t_kn  [label="Venue knowledge (9)\nNeurIPS · ICML · ACL · IEEE · ACM · arXiv\nUSPTO · policy memo · NSF/NIH grant", fillcolor="#f6f1df"];
    t_tpl [label="LaTeX templates · skeletons\nreproducibility stack", fillcolor="#f6f1df"];
  }

  // ---- Document recipes ----
  recipes [label="Document recipes (10)\npatent-brief · policy-brief · white-paper\nempirical · benchmark · replication · grant\nliterature-review · idea-generation · paperbanana-figure",
           shape=box, style="filled,rounded", fillcolor="#fbe9d0"];

  // ---- Wiring (kept sparse for readability) ----
  entry -> q [style=bold];
  paper -> dr [style=dashed, label="paper slice"];
  recipes -> q [style=dotted, label="one-shot"];

  a_q   -> sp  [style=dashed, color="#55A868"];
  a_ev  -> ex  [style=dashed, color="#55A868"];
  a_rev -> cr  [style=dashed, color="#55A868"];
  a_au  -> dr  [style=dashed, color="#55A868"];
  a_orch-> q   [style=dashed, color="#55A868"];

  b1 -> cr [style=dashed, color="#C44E52"];
  b2 -> pub [style=dashed, color="#C44E52"];

  t_exp -> ex  [style=dashed, color="#8172B3"];
  t_fig -> dr  [style=dashed, color="#8172B3"];
  t_kn  -> pub [style=dashed, color="#8172B3"];
  t_tpl -> pub [style=dashed, color="#8172B3"];
}
