// Research bundle: a toolkit of AI assistants that help with the full
// academic research workflow — from sharpening hypotheses and running
// stats to drafting papers, making figures, formatting for conferences,
// and auditing experiment integrity before trusting results.
digraph research {
    rankdir=LR
    fontname="Helvetica"
    fontsize=12
    label="Research Bundle — AI Assistants for Academic Work\nHypothesis design, statistics, writing, figures, venue formatting, experiment integrity\nresearch v0.5.0 — bundle repo"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    root_research [label="Research Toolkit (main bundle)\nresearch v0.5.0\n1 tool · 0 agents\n~3400 tok aggregate", shape=box, fillcolor="#80cbc4", style="filled,rounded,bold", penwidth=2]

    subgraph cluster_standalones {
        label="Standalone Bundles — used on their own"
        style="filled"
        fillcolor="#f9f9f9"
        color="#999999"

        sta_dev [label="Developer Tools\ndev", shape=box, fillcolor="#80cbc4", style="filled,rounded"]
    }

    subgraph cluster_agents {
        label="Research Assistants (Agents) — each a specialist for one part of the workflow"
        style="filled"
        fillcolor="#f9f9f9"
        color="#999999"

        agt_citation_manager [label="Citations & Bibliography\ncitation-manager\n~235 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_figure_designer [label="Charts & Figures\nfigure-designer\n~276 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_honest_critic [label="Tough-Love Reviewer\nhonest-critic\n~235 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_hypothesis_designer [label="Research Question Shaper\nhypothesis-designer\n~202 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_methodologist [label="Study Design Advisor\nmethodologist\n~232 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_preregistration_reviewer [label="Pre-Study Plan Checker\npreregistration-reviewer\n~244 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_research_coordinator [label="Workflow Orchestrator\nresearch-coordinator\n~240 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_statistician [label="Stats & Analysis Guide\nstatistician\n~231 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_technical_writer [label="Paper & Brief Drafter\ntechnical-writer\n~259 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        agt_venue_formatter [label="Conference & Venue Formatter\nvenue-formatter\n~239 tok desc", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
    }

    subgraph cluster_tools {
        label="Tools (Capabilities) — Python modules that run checks or generate artifacts"
        style="filled"
        fillcolor="#f9f9f9"
        color="#999999"

        tool_experiment_audit [label="Experiment Integrity Audit\ntool-experiment-audit v0.1.0\n10 checks · PASS/FAIL/SUSPICIOUS\n~480 tok desc", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    }

    subgraph cluster_context {
        label="Shared Instructions — background knowledge every assistant reads"
        style="filled"
        fillcolor="#f9f9f9"
        color="#999999"

        ctx_instructions_md [label="How-to-use guide\ninstructions.md\n~2490 tok", shape=box, fillcolor="#e1bee7", style="filled,rounded"]
        ctx_integrity_awareness [label="Experiment Integrity Awareness\nexperiment-integrity-awareness.md\n~900 tok", shape=box, fillcolor="#e1bee7", style="filled,rounded"]
    }

    subgraph cluster_legend {
        label="Legend — what each shape and color means"
        style="filled"
        fillcolor="white"
        color="#cccccc"
        fontsize=9

        leg_root [label="main bundle", shape=box, fillcolor="#80cbc4", style="filled,rounded,bold", fontsize=9]
        leg_behavior [label="behavior (how-to rule)", shape=box, fillcolor="#e0f2f1", style="filled,rounded", fontsize=9]
        leg_agent [label="agent (assistant)", shape=box, fillcolor="#c8e6c9", style="filled,rounded", fontsize=9]
        leg_module [label="module (code piece)", shape=box, fillcolor="#bbdefb", style="filled,rounded", fontsize=9]
        leg_provider [label="provider (AI service)", shape=box, fillcolor="#e0e0e0", style="filled,rounded", fontsize=9]
        leg_context [label="context (reference doc)", shape=box, fillcolor="#e1bee7", style="filled,rounded", fontsize=9]
        leg_standalone [label="standalone bundle", shape=box, fillcolor="#80cbc4", style="filled,rounded", fontsize=9]
        leg_experiment [label="experimental piece", shape=box, fillcolor="#e1bee7", style="filled,rounded", fontsize=9]
        leg_ext_cost [label="external, adds cost", shape=box, fillcolor="#80cbc4", style="dashed", color="red", penwidth=2, fontsize=9]
        leg_ext_muted [label="external, free", shape=box, fillcolor="#f5f5f5", style="dashed", fontsize=9]
    }

    disclaimer [label="How to read the numbers:\nToken estimates use ~4 characters per token\nSolid border = lives in this repo (counted)\nDashed + red = pulled from elsewhere, adds hidden cost\nDashed + muted = pulled from elsewhere, no cost\nNot included: sub-sessions, runtime-dynamic content", shape=note, fillcolor="#eceff1", style="filled", fontsize=9]


    root_research -> ctx_instructions_md [style=dotted, color=purple]
    root_research -> ctx_integrity_awareness [style=dotted, color=purple]
    root_research -> tool_experiment_audit [label="mounts", color="#1565c0"]
    sta_dev -> root_research [label="extends", style=dashed]
}
